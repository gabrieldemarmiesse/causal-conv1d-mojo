# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv
# pixi environments
.pixi/*
!.pixi/config.toml

# vendored upstream sources for reference (not built)
/modular/
/causal-conv1d/

# pytest
.pytest_cache/

# mojo extension build artifact (manual build) and runtime-compile cache
*.so
__mojocache__/
flash-attention/
/cines

# PTX dumps from `dump_asm` in each subpackage's compile_function call.
# Refreshed on every first-import build; one file per comptime variant.
/ptx/

# Benchmark/asm artifacts — all regenerated by scripts/master_bench.py
# (baseline cache, our dumped PTX/SASS, and the upstream reference PTX/SASS),
# so they're machine/toolchain-specific and not worth tracking.
scripts/baselines/
scripts/assembly/
scripts/reference_assembly/

# mojo kgen trace dumps
kgen.trace.json.time*
.rocprofv3/

# Vendored third-party Claude Code skills (kept local, not tracked).
.claude/skills/

# Slurm job submission scripts and output files (cluster-specific, not part of the codebase).
*.slurm
ccm_test_mi300_*.out
ccm_test_mi300_*.err
