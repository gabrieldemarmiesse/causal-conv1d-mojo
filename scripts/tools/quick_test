#!/usr/bin/env bash
# Run a *small, targeted* slice of the test suite — at most a handful
# of tests, picked by -k expression. Use this to validate correctness
# after a perf change without paying for the full 30-min cold suite.
#
# Examples:
#   ./scripts/tools/quick_test fwd 'width4 and fp16 and seqlen2048'
#   ./scripts/tools/quick_test bwd 'width4 and fp16 and not silu'
#   ./scripts/tools/quick_test update 'width4 and fp16'
#
# Cap: max 3 tests (-x stops on first failure). Tweak the -k expression
# until the count is small enough. Run `pixi run -e bench pytest tests/ --collect-only -q | wc -l`
# (or its uv equivalent) to peek at the matrix.

set -euo pipefail

KIND="${1:-}"
KEXPR="${2:-}"
if [[ -z "$KIND" || -z "$KEXPR" ]]; then
    echo "Usage: $0 <fwd|bwd|update> '<pytest -k expr>'" >&2
    exit 2
fi

here="$(cd "$(dirname "$0")" && pwd)"
repo="$(dirname "$(dirname "$here")")"

case "$KIND" in
    fwd)   target="tests/test_fwd.py" ;;
    bwd)   target="tests/test_bwd.py" ;;
    update) target="tests/test_update.py" ;;
    *) echo "kind must be fwd|bwd|update" >&2; exit 2 ;;
esac

exec flock /tmp/.gpu_bench_lock \
    uv run pytest "$repo/$target" -k "$KEXPR" -x --maxfail=1 -q
